# BHELA Houseboat WordPress Theme
# .gitignore

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.settings/

# Node (if added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# WordPress core (theme only repo)
wp-config.php
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/backup*/
wp-content/debug.log

# Build artifacts
*.map
*.min.css.map
*.min.js.map

# Logs
*.log
error_log

# Backup files
*.bak
*.orig
*.backup

# Compiled files
*.sass-cache/
.cache/

# Environment
.env
.env.*
